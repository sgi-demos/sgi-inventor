#
# style22   inactive:  LINES   DIM PURPLE  
#             active:    ""    BRIGHT PURPLE 
#
#-----------------------------------------------------------------------


Group {
    Label {
	label "style0"
    }
    Material {
	diffuseColor	[ 0. 1. 0. ]     # GREEN
	emissiveColor	[ 0. 1. 0. ]
	transparency    0.0
    }
    DrawStyle {
	lineWidth 2
    }
    LightModel {
	model PHONG
    }
    Texture2 {}
}
