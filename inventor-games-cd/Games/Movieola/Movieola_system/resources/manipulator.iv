#
# style10   inactive:  OPAQUE  DIM GREEN  
#             active:    ""    BRIGHT GREEN 
#
# style11   inactive:  FROSTY  DIM GREEN  
#             active:    ""    BRIGHT GREEN 
#
# style12   inactive:  LINES   DIM GREEN  
