#Inventor V1.0 ascii

#
# STYLES FOR MANIPULATORS
#
#-----------------------------------------------------------------------
# PRIMARY OBJECTS   -- Styles 0 through 9 
#-----------------------------------------------------------------------
#
# style0   inactive:  OPAQUE  WHITE  
#            active:    ""    YELLOW 
#
# style1   inactive:  FROSTY  WHITE  
#            active:    ""    YELLOW 
#
# style2   inactive:  LINES   WHITE  
#            active:    ""    YELLOW 
#
# style3   inactive:  INVISIBLE
#            active:    ""
#
#-----------------------------------------------------------------------
# SECONDARY OBJECTS -- Styles 10 through 19
