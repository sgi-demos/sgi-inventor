DEF RING_SHAPE_INVISIBLE
Separator {
    DrawStyle {
	style INVISIBLE
    }
    USE RING_SHAPE_MESH
}

DEF RING_SHAPE_UNPICKABLE_OUTLINE
Separator {
    PickStyle {
	style UNPICKABLE
    }
    USE RING_SHAPE_LINE_SET
}

Separator {
    Label {
	label "trackballRotater"
    }
    Label {
	label "trackballRotaterActive"
    }
    Sphere { radius 1.732 }
}

Separator {
    Label {
	label "trackballXRotater"
    }
    Label {
	label "trackballXRotaterActive"
    }
    Scale {
	scaleFactor    1.77 1.77 1.77
    }
    RotationXYZ {
	axis Z
	angle 1.57079
    }
    USE Y_RING_COORDS_AND_NORMALS

    # draw invisible so it can be picked!
    USE RING_SHAPE_INVISIBLE

    # now draw an unpickable line
    USE RING_SHAPE_UNPICKABLE_OUTLINE
}

Separator {
    Label {
	label "trackballYRotater"
    }
