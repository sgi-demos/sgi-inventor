DEF RING_SHAPE_LINE_SET
IndexedLineSet {
    coordIndex [
	0,  1,  3,  5,  7,  9, 11, 13, 15, 14, 12, 10,  8,  6,  4,  2,  0, -1,
	16, 17, 19, 21, 23, 25, 27, 29, 31, 30, 28, 26, 24, 22, 20, 18, 16, -1,
