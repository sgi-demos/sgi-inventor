		}
		IndexedTriangleStripSet {
		    coordIndex	[ 2, 3, 1, 11, 0, -1, 10, 11,
				      9, 8, -1, 8, 11, 7, 6, -1,
				      6, 11, 5, 4, -1, 11, 3, 4,
				      -1, 15, 14, 16, 24, 17, 18, -1,
				      23, 22, 24, 21, 20, -1, 20, 19,
				      24, 18, -1, 13, 24, 14, -1 ]
		    normalIndex	[ 1, 2, 0, 5, 24, -1, 4, 5,
				      3, 6, -1, 6, 5, 9, 12, -1,
				      12, 5, 15, 18, -1, 5, 2, 18,
				      -1, 31, 32, 30, 33, 50, 47, -1,
				      34, 35, 33, 38, 41, -1, 41, 44,
				      33, 47, -1, 56, 33, 32, -1 ]
		}
	    }
	}
    }
  }

  # The children of this switch node represent the different stages of
  # the animation.  A calculator engine controls how long each child
  # is active.
  # The total animation includes
  #  1) The plain puck stands up, and jumps up to the height of the
  #	victory puck with legs and then turns into the victur puck.
  #  2) The victory puck moves forward to the center line while making 
  #	3 complete turns - in time with the music.
  #	Each turn is a separate stage so we can pause slightly between 
  #	each one.
  
  DEF victoryStages Switch {

    whichChild -1 = DEF stagesCalc Calculator {
	a 0 = DEF victoryOneShot OneShot {
	    duration 14.4
	    flags (HOLD_FINAL|RETRIGGERABLE)
	} . ramp
	expression [ 
	    "ta = 10 * a",
	    "oa = (ta<2.0) ? 0 : ( (ta<5.0) ? 1 : ( (ta<7.5) ? 2 : ( (ta<10.0) ? 3 : 3 ) ) )" 
	]
    } . oa

    # stage 0 
    # Plain puck stands up.
    Separator {
	Translation {
	    translation = InterpolateVec3f {
		input0 0 0 0
		input1 0 9.045 0
		alpha 0 = DEF plainPuckCalc Calculator {
		    a 0 = USE victoryOneShot . ramp
        	    expression [ 
		    	"ta = 10 * a",
		    	"oa = (ta<1.5) ? ((ta>.5) ? (10*(a-.05)) : 0) : 1",
		   # 	"ob = (ta<1.5) ? 0 : ((ta>1.75) ? 1 : (40*(a-.15)))",
		    ]
	        } . oa	
	    } .output
	}
	DEF dancePuckPos Translation {}
        RotationXYZ {
	    axis X
	    angle 0 = DEF stageZero InterpolateFloat {
		input0 0
		input1 1.57079
		alpha 0 = USE plainPuckCalc . oa
	    } . output
	}
 	Scale {
	    scaleFactor = InterpolateVec3f {
		input0 1 1 1
		input1 1.5 1.5 1.5
		alpha 0 = USE plainPuckCalc . oa
	    } . output
	}

	Material {
	    ambientColor	0.111586 0.111586 0.111586
	    diffuseColor	0.3 0.3 0.3
	    specularColor	0.3 0.3 0.3
	    emissiveColor	0 0 0
	    transparency	0
	}
	Cylinder { radius 3 height 1.5 }
    }

    # stage 1
    Separator {
	Translation {
	    translation = DEF stageOneTrans InterpolateVec3f {
		input0 0 0 0
		input1 0 0 30
		alpha 0 = DEF victoryPuckCalc Calculator {
		    a 0 = USE victoryOneShot . ramp
        	    expression [ 
		    	"ta = 10 * a",
		    	"oa = (ta<2.75) ? 0 : ((ta<5) ? (4.44*(a-.275)) : 1)",
		    ]
	        } . oa	
	    } .output
	}

	USE dancePuckPos 

        RotationXYZ {
	    axis Y
	    angle 0 = DEF stageOneRot InterpolateFloat {
		input0 0
		input1 6.283184
		alpha 0 = USE victoryPuckCalc . oa
	    } . output
	}

        USE victoryPuck
    }

    # stage 2
    Separator {
	Translation {
	    translation = DEF stageTwoTrans InterpolateVec3f {
		input0 0 0 30 
		input1 0  0 60 
		alpha 0 = DEF victoryPuckCalc2 Calculator {
		    a 0 = USE victoryOneShot . ramp
        	    expression [ 
		    	"ta = 10 * a",
		    	"oa = (ta<5.25) ? 0 : ((ta<7.5) ? (4.44*(a-.525)) : 1)",
		    ]
	        } . oa	
	    } .output
	}

	USE dancePuckPos 

        RotationXYZ {
	    axis Y
	    angle 0 = DEF stageTwoRot InterpolateFloat {
		input0 0
		input1 6.283184
		alpha 0 = USE victoryPuckCalc2 . oa
	    } . output
	}

        USE victoryPuck 
     }

     # stage 3
     Separator {
	Translation {
	    translation = DEF stageThreeTrans InterpolateVec3f {
		input0 0 0 60 
		input1 0 0 90 
		alpha 0 = DEF victoryPuckCalc2 Calculator {
		    a 0 = USE victoryOneShot . ramp
        	    expression [ 
		    	"ta = 10 * a",
		    	"oa = (ta<7.75) ? 0 : ((ta<10.0) ? (4.44*(a-.775)) : 1)",
		    ]
	        } . oa	
	    } .output
	}

	USE dancePuckPos 

        RotationXYZ {
	    axis Y
	    angle 0 = DEF stageThreeRot InterpolateFloat {
		input0 0
		input1 6.283184
		alpha 0 = USE victoryPuckCalc2 . oa
	    } . output
	}

        USE victoryPuck 
    }
  }
}
