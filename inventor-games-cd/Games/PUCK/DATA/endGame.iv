				      4.47035e-07 2.98023e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.60871e-07 -2.5543e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.60871e-07 -2.5543e-08 -1,
				      4.60871e-07 -2.5543e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.60871e-07 -2.5543e-08 -1,
				      4.22192e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.22192e-07 2.98023e-08 -1,
				      4.22192e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
				      4.22192e-07 2.98023e-08 -1,
				      4.47035e-07 2.98023e-08 -1,
				      4.44589e-07 1.75034e-08 -1,
