#Inventor V2.0 ascii

DEF endGame Separator {
    
    DEF endGameLight Switch {
	DirectionalLight { direction  0 -.75 -1 }  # light for Player 0
	DirectionalLight { direction  0 -.75 1 }   # light for Player 1
    }

    #
    # "You lost" message for the loser 
    #
    Switch {
	whichChild 0 = DEF loserOneShot OneShot {
	    duration 8.0
	} . isActive
	
	# dummy child displayed when the oneshot is not active
	Separator { 
	    Font { size 24 }
        }

	# "you lost" message drops down when the oneshot is active
	Separator {
	    Material { diffuseColor 1. 0 0 }
	    Translation {
	        translation = InterpolateVec3f {
		    input0 0 30 0
		    input1 0 0  0
		    alpha 0 = DEF youLostCalc Calculator {
		        a 0 = USE loserOneShot . ramp
        	        expression [ 
		    	    "ta = 10 * a",
		    	    "oa = (ta<4) ? (2.5*a) : 1",
		    	    "ob = (ta>=4) ? ((ta<4.5) ? (20*(a-.40)) : 1 ) : 0",
		    	    "oc = (ta>=4.5) ? ((ta<5) ? (20*(a-.45)) : 1 ) : 0",
		        ]
	            } . oa	} .output
	    }
	    Translation {
	        translation = InterpolateVec3f {
		    input0 0 0 0
		    input1 0 1 0
		    alpha 0 = USE youLostCalc . ob
		} .output
	    }
	    Translation {
	        translation = InterpolateVec3f {
		    input0 0 0 0
		    input1 0 -1 0
		    alpha 0 = USE youLostCalc . oc
		} .output
	    }
	    DEF loserText Separator {
	    	DEF loserTransform Transform { 
		    scaleFactor 1 1.2 5 
		    translation 0 0 15
	        }
	        Complexity { value 0.7 }
	        Font { size 16 }
	        Text3 { string "You Lost!" justification CENTER parts ALL }
	    }
	
	    # shadow
            LightModel { model BASE_COLOR }
            BaseColor { rgb 0.4 0.4 0.4 }
            DEF loserShadow Switch {
                whichChild 0
                MatrixTransform {           # shadow transform for player 0
                    matrix  1  0 0  0
                            -.5  0 -2 0
                            0  0 1 0
                            0  0 0 1
                }
                MatrixTransform {           # shadow transform for player 1
                    matrix  1  0 0  0
                            -.5  0 2 0
                            0  0 1 0
                            0  0 0 1
                }
            }
	    USE loserText
	}
    }


    #
    # Victory dance for the winner
    #

    # The definition of the victory puck geometry (used later)
    Switch {
      whichChild -1
      DEF victoryPuck Separator {
	Scale { scaleFactor 1.5 1.5 1.5 }
	Translation { translation  -5.17 0 0 }
	Separator {
	    Material {
		ambientColor	0.111586 0.111586 0.111586
		diffuseColor	0.3 0.3 0.3
		specularColor	0.3 0.3 0.3
		emissiveColor	0 0 0
		transparency	0
	    }
	    MatrixTransform {
		matrix	1 0 0 0
			0 -3.69549e-06 1 0
			0 -1 -3.69549e-06 0
			5.17 6.03 0 1
	    }
	    Cylinder {
		radius	3
		height	1.5
	    }
	}
	Separator {
	    Material {
		ambientColor	0.936975 0.0923259 0.42843
		diffuseColor	0.536861 0.0529003 0.245479
	    }
	    ShapeHints {
		vertexOrdering	COUNTERCLOCKWISE
		shapeType	SOLID
		faceType	UNKNOWN_FACE_TYPE
	    }
	    NormalBinding {
		value	PER_VERTEX_INDEXED
	    }
	    Coordinate3 {
