#----------------------------------------
#used by the Axle class
#----------------------------------------

DEF axleMovingFeedback Separator {
    renderCaching ON
    USE PURPLE_LINE
    Coordinate3 { point [ 0 0 -1, 0 0 1 ] }
    LineSet {}
}
DEF axleConnectFeedback Separator {
    renderCaching ON
    USE PURPLE_LINE
    Coordinate3 { point [ 0 0 -1, 0 0 1 ] }
    LineSet {}
    USE YELLOW_LINE
    DrawStyle { lineWidth 3 linePattern 0xf0f0 }
    Coordinate3 { point [ 0 0 -4, 0 0 4 ] }
    LineSet {}
}
DEF axleDisconnectFeedback Separator {
    renderCaching ON
    USE PURPLE_LINE
    Coordinate3 { point [ 0 0 -1, 0 0 1 ] }
    LineSet {}
    USE YELLOW_LINE
    DrawStyle { lineWidth 3 linePattern 0xf0f0 }
    Coordinate3 { point [ 0 -4 0, 0 4 0 ] }
    LineSet {}
}

