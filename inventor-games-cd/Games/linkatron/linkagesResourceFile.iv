DEF tableBottomTranslator Separator {
    renderCaching ON
    USE MAGENTA
    Translation { translation -.05 0 0 }
    Cube { width .1 }
}
DEF tableBottomTranslatorActive Separator {
    renderCaching ON
    USE YELLOW
    Translation { translation -.05 0 0 }
    Cube { width .1 }
}

DEF tableTopTranslator Separator {
    renderCaching ON
    USE PINK
    Cube { width .1 height 2 depth .1 }
}
DEF tableTopTranslatorActive Separator {
    renderCaching ON
    USE YELLOW
    Cube { width .1 height 2 depth .1 }
}

DEF tableActivePlaneGeom Separator {
    renderCaching ON
    USE WHITE_LINE
    Coordinate3 { point [ -1 -1 0, -1 1 0, 1 1 0, 1 -1 0 ] }
    LineSet {}
}

DEF tableActivePlaneTranslator Separator {
    renderCaching ON
    Separator {
	USE PINK
	Translation { translation 0 0 .75 }
	Cube { width .5 height .15 depth .5 }
    }
    USE WHITE_LINE
    PickStyle { style UNPICKABLE }
    Coordinate3 { point [ 0 0 0, 0 0 1 ] }
    LineSet {}
}

DEF tableActivePlaneTranslatorActive Separator {
    renderCaching ON
    USE YELLOW
    Separator {
	Translation { translation 0 0 .75 }
	Cube { width .5 height .15 depth .5 }
    }
    Coordinate3 { point [ 0 0 0, 0 0 1 ] }
    LineSet {}
}

