#Inventor V2.0 ascii

#----------------------------------------
# colors shared by other resources below
#----------------------------------------
DEF BLUE Material {
    diffuseColor	0 0.710535 0.8
    emissiveColor	0 0.0906295 0.102041
}
DEF YELLOW Material {
    diffuseColor	0.8 0.8 0
    emissiveColor	0.1 0.1 0
}
DEF ORANGE Material {
    diffuseColor	1.0 0.7 0
    emissiveColor	0.12 0.08 0
}
DEF PINK Material {
    diffuseColor	0.8 0 0.266667
    emissiveColor	0.102041 0 0.0340136
}
DEF MAGENTA Material {
    diffuseColor	0.5 0 0.5
    emissiveColor	0.1 0 0.1
}
DEF LAVENDER Material {
    diffuseColor	0.8 0 0.8
    emissiveColor	0.102041 0 0.1
}
DEF WHITE Material {
    diffuseColor	0.8 0.8 0.8
    emissiveColor	0.1 0.1 0.1
}

DEF LIGHT_GREY Material {
    diffuseColor	0.6 0.6 0.6
    emissiveColor	0.075 0.075 0.075
}

DEF CHARCOAL Material {
    diffuseColor	0.1 0.1 0.1
    emissiveColor	0.1 0.1 0.1
}

DEF WHITE_LINE Material {
    emissiveColor	0.8 0.8 0.8
    diffuseColor	0.8 0.8 0.8
}
DEF YELLOW_LINE Material {
    emissiveColor	1   1   0
    diffuseColor	1   1   0
}
DEF PURPLE_LINE Material {
    emissiveColor	1   0   1
    diffuseColor	1   0   1
}

#----------------------------------------
# used by the LinkBase class
#----------------------------------------

DEF linkBaseErrorMaterial Material {
    diffuseColor	1  0 0
    emissiveColor	.5 0 0
}

#----------------------------------------
# used by the graph paper class 
#----------------------------------------

DEF graphPaperPaperAppearance AppearanceKit {
    material USE WHITE
}

DEF graphPaperLineAppearance AppearanceKit {
    material USE LIGHT_GREY
    drawStyle DrawStyle { lineWidth 3 }
}


