AR            = ar cq
RANLIB        = ranlib -s
QMAKE         = /Users/ilab/BuildSlaveWorkingDirectory/WD/MeVis/ThirdParty/Sources/Qt4/qt_source/bin/qmake
TAR           = tar -cf
COMPRESS      = gzip -9f
