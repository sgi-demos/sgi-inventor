	@$(CHK_DIR_EXISTS) tmp/debug/obj/Inventor_debug1.0.0 || $(MKDIR) tmp/debug/obj/Inventor_debug1.0.0 
	$(COPY_FILE) --parents $(SOURCES) $(DIST) tmp/debug/obj/Inventor_debug1.0.0/ && $(COPY_FILE) --parents lib/database/src/so/engines/SoCalcParse.y tmp/debug/obj/Inventor_debug1.0.0/ && $(COPY_FILE) --parents lib/database/src/so/engines/SoCalcParse.y tmp/debug/obj/Inventor_debug1.0.0/ && (cd `dirname tmp/debug/obj/Inventor_debug1.0.0` && $(TAR) Inventor_debug1.0.0.tar Inventor_debug1.0.0 && $(COMPRESS) Inventor_debug1.0.0.tar) && $(MOVE) `dirname tmp/debug/obj/Inventor_debug1.0.0`/Inventor_debug1.0.0.tar.gz . && $(DEL_FILE) -r tmp/debug/obj/Inventor_debug1.0.0


clean:compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


####### Sub-libraries

distclean: clean
	-$(DEL_FILE) -r ../../../lib/Inventor.framework
	-$(DEL_FILE) Makefile.inventor.Debug


check: first

compiler_objective_c_make_all:
compiler_objective_c_clean:
compiler_yacc_decl_make_all: SoCalcParse_yacc.h
compiler_yacc_decl_clean:
	-$(DEL_FILE) SoCalcParse_yacc.h
SoCalcParse_yacc.h: lib/database/src/so/engines/SoCalcParse.y
	yacc -d -p SoCalcParse -b SoCalcParse lib/database/src/so/engines/SoCalcParse.y
	 rm -f SoCalcParse_yacc.h SoCalcParse_yacc.cpp
	 mv -f SoCalcParse.tab.h SoCalcParse_yacc.h
	 mv -f SoCalcParse.tab.c SoCalcParse_yacc.cpp
	

compiler_yacc_impl_make_all: SoCalcParse_yacc.cpp
compiler_yacc_impl_clean:
	-$(DEL_FILE) SoCalcParse_yacc.cpp
SoCalcParse_yacc.cpp: lib/database/src/so/engines/SoCalcParse.y \
		SoCalcParse_yacc.h
	


compiler_lex_make_all:
compiler_lex_clean:
compiler_rez_source_make_all:
compiler_rez_source_clean:
compiler_rcc_make_all:
compiler_rcc_clean:
compiler_uic_make_all:
compiler_uic_clean:
compiler_image_collection_make_all: tmp/debug/ui/qmake_image_collection.cpp
compiler_image_collection_clean:
