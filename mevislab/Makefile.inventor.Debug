QMAKE_TARGET  = Inventor_debug
DESTDIR       = ../../../lib/
TARGET        = Inventor_debug
TARGETA       = ../../../lib/libInventor_debug.a
TARGETD       = Inventor.framework/Versions/2.5/Inventor_debug
TARGET0       = Inventor.framework/Inventor_debug

####### Custom Compiler Variables
QMAKE_COMP_QMAKE_OBJECTIVE_CFLAGS = -pipe \
		-stdlib=libc++ \
		-Qunused-arguments \
		-fno-show-column \
		-fno-caret-diagnostics \
		-fno-diagnostics-show-option \
		-fno-color-diagnostics \
		-g \
		-arch \
		x86_64 \
		-Wall \
		-W


first: all
####### Implicit rules

.SUFFIXES: .o .c .cpp .cc .cxx .C

.cpp.o:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o "$@" "$<"

.cc.o:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o "$@" "$<"

.cxx.o:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o "$@" "$<"

.C.o:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o "$@" "$<"

.c.o:
	$(CC) -c $(CFLAGS) $(INCPATH) -o "$@" "$<"

####### Build rules

