../../../lib/Inventor.framework/$(TARGET):  $(OBJECTS) $(SUBLIBS) $(OBJCOMP)  
	@$(CHK_DIR_EXISTS) ../../../lib/Inventor.framework/ || $(MKDIR) ../../../lib/Inventor.framework/ 
	-$(DEL_FILE) $(TARGET) $(TARGET0) $(DESTDIR)$(TARGET0)
	$(LINK) $(LFLAGS) -o $(TARGET) $(OBJECTS) $(LIBS) $(OBJCOMP)
	@$(CHK_DIR_EXISTS) "`dirname $(DESTDIR)$(TARGETD)`" || $(MKDIR) "`dirname $(DESTDIR)$(TARGETD)`" 
	-$(MOVE) $(TARGET) $(DESTDIR)$(TARGETD)
	@$(CHK_DIR_EXISTS) "`dirname $(DESTDIR)$(TARGET0)`" || $(MKDIR) "`dirname $(DESTDIR)$(TARGET0)`" 
	-ln -s Versions/2.5/$(TARGET) $(DESTDIR)$(TARGET0)
	-$(DEL_FILE) ../../../lib/Inventor.framework/Versions/Current
	-ln -s 2.5 ../../../lib/Inventor.framework/Versions/Current
	



staticlib: $(TARGETA)

$(TARGETA):  $(OBJECTS) $(OBJCOMP) 
	-$(DEL_FILE) $(TARGETA) 
	$(AR) $(TARGETA) $(OBJECTS)
	$(RANLIB) $(TARGETA)

