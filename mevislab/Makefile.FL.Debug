	-$(DEL_FILE) $(TARGET)
	$(AR) $(TARGET) $(OBJECTS)
	$(RANLIB) $(TARGET)
	-$(DEL_FILE) libFL/$(TARGET)
	-$(MOVE) $(TARGET) libFL/


