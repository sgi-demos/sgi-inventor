    DEF MineDormant Separator {
	Material {
	    diffuseColor .8 .8 .8
	    emissiveColor .3 .3 .3
	    specularColor .6 .6 .6
	    shininess .4
	}
	USE _MineBody
	USE _MineSpikes
    }

    DEF MineActive Separator {
	Material {
	    diffuseColor 1 0 0
	    emissiveColor 1 0 0
	    specularColor .6 .6 .6
	    shininess .4
	}
	USE _MineBody
	USE _MineSpikes
    }

    DEF MineExploding1 Separator {
	DEF _MineExplodingStuff Group {
	    LightModel { model BASE_COLOR }
	    MaterialBinding { value PER_VERTEX }
	    BaseColor { rgb [1 .1 .1, 1 .4 .2] }
	}
	USE _MineRandomPieces
    }

    DEF MineExploding2 Separator {
	USE _MineExplodingStuff
	Scale { scaleFactor 3 3 3 }
	USE _MineRandomPieces
    }

    DEF MineDeactivating1 Separator {
	Scale { scaleFactor .7 .7 .7 }
	Material {
	    ambientColor ~
	    diffuseColor  .3 .3 .3
	    specularColor ~
	    emissiveColor .5 .5 0
	    shininess ~
	    transparency ~
	}
	USE _MineSphere
