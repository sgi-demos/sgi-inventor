#Inventor V2.0 ascii

# This scene graph is used to time texturing performance. It is
# never rendered as part of the game. Since there is no light in this
# scene and the texture is black, it is displayed as a dark window.

Separator {
    OrthographicCamera { height 2 }
    # This is used to scale the square based on the window size
    DEF TextureTimeScale Scale {}
    Texture2 { image 1 1 3 0x000000 }
    Coordinate3 { point [-1 1 0, -1 -1 0, 1 -1 0, 1 1 0] }
    FaceSet {}
}
